#define _CRT_SECURE_NO_WARNINGS
#include <stdio.h>
#include <stdlib.h>
#include <ctype.h>

void ubah(char input[], char result[], int* position) {
	for (int i = 0; input[i] != '\0' && input[i] != '\n'; i++) {
		*position += sprintf(result + *position, "%X", input[i]);

	}

	printf("Result of ascii hexa %s", result);
}

int main() {
	char input[51];
	char result[200];
	int position = 0;

	printf("Input a string of character\n");
	fgets(input, sizeof(input), stdin);

	ubah(input, result, &position);

	return 0;
}
