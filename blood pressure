#define _CRT_SECURE_NO_WARNINGS
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <ctype.h>

#define FILE_NAME "blood_press.txt"

void clearBuffer() {
    int c=0;
    while ((c = getchar()) != '\n' && c != EOF);
}

int readString(char* buffer, int size, const char* prompt) {
    printf("%s", prompt);
    if (fgets(buffer, size, stdin) == NULL) return 0;

    if (buffer[0] == '\n') {
        printf("[ERROR] Input cannot be empty! Please try again.\n");
        return 0;
    }
    if (strchr(buffer, '\n') == NULL) {
        printf("[ERROR] Input exceeds maximum length!\n");
        clearBuffer();
        return 0;
    }

    buffer[strcspn(buffer, "\n")] = '\0';
    return 1;
}

int isValidDate(const char* date) {
    if (strlen(date) != 8) return 0;
    for (int i = 0; i < 8; i++) {
        if (!isdigit(date[i])) return 0;
    }

    int year=0, month=0, day=0;
    if(sscanf(date, "%4d%2d%2d", &year, &month, &day) ==3){

    if (month < 1 || month > 12) return 0;
    if (day < 1 || day > 31) return 0;

    if (year > 2026) return 0;
    if (year == 2026 && month > 4) return 0;
    if (year == 2026 && month == 4 && day > 14) return 0;
    }
    else {
        return 0;
    }
    return 1;
}

int formatTime(char* time_str) {
    if (strchr(time_str, ':') == NULL) return 0;

    int h=0, m=0;
    if (sscanf(time_str, "%d:%d", &h, &m) != 2) return 0;

    if (h < 0 || h > 23 || m < 0 || m > 59) return 0;

    sprintf(time_str, "%02d:%02d", h, m);
    return 1;
}


void inputBloodPressure() {
    char buffer[100] = { '\0' };
    char date[20] = { '\0' }, time[20] = { '\0' };
    int systole, diastole;

    while (1) {
        if (!readString(buffer, sizeof(buffer), "Input Date, Time, Systole, Diastole (YYYYMMDD HH:MM SYS DIA): ")) continue;

        int parsed_items = sscanf(buffer, "%s %s %d %d", date, time, &systole, &diastole);

        if (parsed_items != 4) {
            printf("[ERROR] Invalid format! Ensure you input exactly 4 items separated by spaces.\n");
            continue;
        }

        if (!isValidDate(date)) {
            printf("[ERROR] Invalid date format or date is in the future (Limit: 20260414).\n");
            continue;
        }

        if (!formatTime(time)) {
            printf("[ERROR] Invalid time format! Use HH:MM.\n");
            continue;
        }

        if (systole <= 0 || diastole <= 0) {
            printf("[ERROR] Diastole cant be more higher than systole.\n");
            continue;
        }
        if ( diastole > systole) {
            printf("[CRITICAL WARNING]Not making any sense. Diastole cant be more higher than systole\n");
            return;
        }
        if (systole > 350 || diastole > 350) {
            printf("[CRITICAL WARNING] Dangerously high blood pressure! Go to the hospital immediately! Record discarded.\n");
            return; 
        }

        break; 
    }

    FILE* fp = fopen(FILE_NAME, "a");
    if (fp == NULL) {
        printf("[FATAL ERROR] Cannot open file for writing!\n");
        return;
    }

    fprintf(fp, "%s %s %d %d\n", date, time, systole, diastole);
    fclose(fp);
}

void searchBloodPressure() {
    char search_date[20] = {'\0'};

    while (1) {
        if (!readString(search_date, sizeof(search_date), "Input Date to search (YYYYMMDD): ")) continue;
        if (!isValidDate(search_date)) {
            printf("[ERROR] Invalid date format!\n");
            continue;
        }
        break;
    }

    FILE* fp = fopen(FILE_NAME, "r");
    if (fp == NULL) {
        printf("[ERROR] Record file not found or is empty.\n");
        return;
    }

    char date[20] = {'\0'}, time[10] = { '\0' };
    int sys=0, dia=0;
    int found = 0;

    while (fscanf(fp, "%s %s %d %d", date, time, &sys, &dia) != EOF) {
        if (strcmp(date, search_date) == 0) {
            if (!found) {
                printf("\n%-15s %-10s %-10s %s\n", "Date", "Time", "Systole", "Diastole");
            }
            printf("%-15s %-10s %-10d %d\n", date, time, sys, dia);
            found = 1;
        }
    }

    if (!found) {
        printf("(No records found for date: %s)\n", search_date);
    }
    else {
        printf("\n"); 
    }

    fclose(fp);
}

int main() {
    char menu_input[20]={'\0'};

    while (1) {
        printf("1) Input Blood Pressure 2) Search Blood Pressure -1) Exit: ");
        if (!readString(menu_input, sizeof(menu_input), "")) continue;

        int menu = atoi(menu_input);

        if (menu == -1) {
            break;
        }
        else if (menu == 1) {
            inputBloodPressure();
        }
        else if (menu == 2) {
            searchBloodPressure();
        }
        else {
            printf("[ERROR] Invalid menu option. Please select 1, 2, or -1.\n");
        }
    }

    return 0;
}


